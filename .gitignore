# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter Notebook
.ipynb_checkpoints/

# Environments / secrets
.env
*.env

# Data: ignore bulky/derived files, but track the source price data,
# the curated events dataset, and the folder placeholders.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/BrentOilPrices.csv
!data/raw/key_events.csv

# Reports: ignore transient PDF exports, but keep the delivered HTML report.
reports/*.pdf
reports/*.html
!reports/interim_report.html

# IDE / OS
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
