# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter Notebook
.ipynb_checkpoints/

# Environments / secrets
.env
*.env

# Data (keep folder structure via .gitkeep, ignore large files)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Reports build artifacts
reports/*.pdf
reports/*.html

# IDE / OS
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
