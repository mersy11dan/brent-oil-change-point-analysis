# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Jupyter Notebook
.ipynb_checkpoints/

# Environments / secrets
.env
*.env

# Data: ignore bulky/derived files, but track the source price data,
# the curated events dataset, and the folder placeholders.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/BrentOilPrices.csv
!data/raw/key_events.csv

# Reports: ignore transient PDF exports, but keep delivered HTML reports
# and model outputs used by the dashboard.
reports/*.pdf
reports/*.html
!reports/interim_report.html
!reports/final_report.html
!reports/model_results.json

# Frontend
frontend/node_modules/
frontend/dist/

# Backend caches
backend/__pycache__/

# IDE / OS
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
